local character = script.Parent
local humanoid = character:WaitForChild("Humanoid")
local camera = workspace.CurrentCamera


humanoid.BreakJointsOnDeath = false

humanoid.Died:Connect(function()
	
	local head = character:FindFirstChild("Head")
	if head then
		camera.CameraSubject = head
	end

	
	for _, descendant in ipairs(character:GetDescendants()) do
		if descendant:IsA("Motor6D") and descendant.Name ~= "RootJoint" then
			local part0 = descendant.Part0
			local part1 = descendant.Part1
			
			if part0 and part1 then
				
				local att0 = Instance.new("Attachment")
				att0.CFrame = descendant.C0
				att0.Parent = part0
				
				local att1 = Instance.new("Attachment")
				att1.CFrame = descendant.C1
				att1.Parent = part1
				
				
				local socket = Instance.new("BallSocketConstraint")
				socket.Attachment0 = att0
				socket.Attachment1 = att1
				socket.LimitsEnabled = true
				socket.TwistLimitsEnabled = true
				socket.Parent = part0
				
				
				descendant:Destroy()
			end
		end
	end
	
	
	for _, descendant in ipairs(character:GetDescendants()) do
		if descendant:IsA("BasePart") then
			if descendant.Name == "HumanoidRootPart" then
				descendant.CanCollide = false -- Keep the root part invisible and non-collidable
			else
				descendant.CanCollide = true
				
				
				descendant.AssemblyLinearVelocity = descendant.AssemblyLinearVelocity + Vector3.new(
					math.random(-5, 5), 
					math.random(0, 5), 
					math.random(-5, 5)
				)
			end
		end
	end
end)
