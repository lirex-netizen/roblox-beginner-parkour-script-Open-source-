local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = script.Parent
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local camera = workspace.CurrentCamera

local normalSpeed = 16
local sprintSpeed = 28
local climbSpeed = 15
local wallRunSpeed = 30
local slideSpeed = 45
local dashSpeed = 60 
local dashTime = 0.2 
local dashCooldown = 1.5 

local slideTime = 0.85
local backflipTime = 0.6
local maxClimbTime = 3
local maxWallRunTime = 2.5

local safeFallDistance = 20
local fallDamageMultiplier = 2.5
local maxGrappleDistance = 200
local grappleSpeed = 100

local sprintAnimationId = "rbxassetid://96859052091595" 
local slideAnimationId = "rbxassetid://2133312581" 
local rollAnimationId = "rbxassetid://3288508192" 
local backflipAnimationId = "rbxassetid://1234567890" 

local raycastParams = RaycastParams.new()
raycastParams.FilterDescendantsInstances = {character}
raycastParams.FilterType = Enum.RaycastFilterType.Exclude

local animator = humanoid:WaitForChild("Animator")

local sprintAnimation = Instance.new("Animation")
sprintAnimation.AnimationId = sprintAnimationId
local sprintTrack = animator:LoadAnimation(sprintAnimation)

local slideAnimation = Instance.new("Animation")
slideAnimation.AnimationId = slideAnimationId
local slideTrack = animator:LoadAnimation(slideAnimation)

local rollAnimation = Instance.new("Animation")
rollAnimation.AnimationId = rollAnimationId
local rollTrack = animator:LoadAnimation(rollAnimation)

local backflipAnimation = Instance.new("Animation")
backflipAnimation.AnimationId = backflipAnimationId
local backflipTrack = animator:LoadAnimation(backflipAnimation)

local function createDust(name, color, direction)
	local dust = Instance.new("ParticleEmitter")
	dust.Name = name
	dust.Parent = rootPart
	dust.Enabled = false
	dust.Rate = 100
	dust.Lifetime = NumberRange.new(0.2, 0.4)
	dust.Speed = NumberRange.new(5, 10)
	dust.Size = NumberSequence.new({ NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0) })
	dust.Color = ColorSequence.new(color)
	dust.EmissionDirection = direction
	return dust
end

local sprintParticles = createDust("SprintDust", Color3.fromRGB(200, 200, 200), Enum.NormalId.Bottom)
local wallParticles = createDust("WallDust", Color3.fromRGB(150, 150, 150), Enum.NormalId.Back)
local slideParticles = createDust("SlideDust", Color3.fromRGB(220, 220, 220), Enum.NormalId.Back)
local dashParticles = createDust("DashDust", Color3.fromRGB(255, 255, 255), Enum.NormalId.Back)
local rollParticles = createDust("RollDust", Color3.fromRGB(180, 180, 180), Enum.NormalId.Bottom)
local flipParticles = createDust("FlipDust", Color3.fromRGB(200, 200, 255), Enum.NormalId.Bottom)

local isSprinting = false
local isClimbing = false
local isWallRunning = false
local isSliding = false
local isDashing = false
local isRolling = false
local isFalling = false
local isBackflipping = false
local isGrappling = false

local actionEndTime = 0
local lastDashTime = 0
local fallStartHeight = 0
local wallRunSide = nil
local currentWallNormal = nil

local grappleTarget = nil
local grappleAtt0 = nil
local grappleAtt1 = nil
local grappleBeam = nil
local grappleVelocity = nil

local targetWalkSpeed = normalSpeed
local targetFOV = 70
local targetTilt = 0
local currentTilt = 0
local flipAngle = 0

local function clearActionForces()
	if rootPart:FindFirstChild("ActionVelocity") then rootPart.ActionVelocity:Destroy() end
	if rootPart:FindFirstChild("ActionAttachment") then rootPart.ActionAttachment:Destroy() end
end

local function stopGrapple()
	if not isGrappling then return end
	isGrappling = false
	targetFOV = isSprinting and 85 or 70
	
	if grappleBeam then grappleBeam:Destroy() end
	if grappleAtt0 then grappleAtt0:Destroy() end
	if grappleAtt1 then grappleAtt1:Destroy() end
	if grappleVelocity then grappleVelocity:Destroy() end
	
	humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
end

local function startGrapple()
	if isGrappling or isClimbing or isWallRunning or isSliding or isRolling or isBackflipping then return end
	
	local rayOrigin = camera.CFrame.Position
	local rayDirection = camera.CFrame.LookVector * maxGrappleDistance
	local hit = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
	
	if hit then
		isGrappling = true
		targetFOV = 110
		grappleTarget = hit.Position
		
		grappleAtt0 = Instance.new("Attachment", rootPart)
		grappleAtt1 = Instance.new("Attachment", hit.Instance)
		grappleAtt1.WorldPosition = hit.Position
		
		grappleBeam = Instance.new("Beam")
		grappleBeam.Attachment0 = grappleAtt0
		grappleBeam.Attachment1 = grappleAtt1
		grappleBeam.FaceCamera = true
		grappleBeam.Width0 = 0.2
		grappleBeam.Width1 = 0.2
		grappleBeam.Color = ColorSequence.new(Color3.new(1, 1, 1))
		grappleBeam.Parent = rootPart
		
		grappleVelocity = Instance.new("LinearVelocity", rootPart)
		grappleVelocity.Attachment0 = grappleAtt0
		grappleVelocity.MaxForce = math.huge
		grappleVelocity.VectorVelocity = (grappleTarget - rootPart.Position).Unit * grappleSpeed
		
		humanoid:ChangeState(Enum.HumanoidStateType.Physics)
	end
end

local function startBackflip()
	if isBackflipping or isClimbing or isWallRunning or isDashing or isRolling or isGrappling then return end
	isBackflipping = true
	flipAngle = 0
	targetFOV = 105
	
	flipParticles:Emit(30)
	if not backflipTrack.IsPlaying then backflipTrack:Play() end
	
	local currentVel = rootPart.AssemblyLinearVelocity
	rootPart.AssemblyLinearVelocity = Vector3.new(currentVel.X, 35, currentVel.Z)
	
	task.delay(backflipTime, function()
		isBackflipping = false
		targetFOV = isSprinting and 85 or 70
		if backflipTrack.IsPlaying then backflipTrack:Stop() end
	end)
end

local function startRoll()
	if isRolling then return end
	isRolling = true
	targetFOV = 90
	
	rollParticles:Emit(40)
	if not rollTrack.IsPlaying then rollTrack:Play() end
	
	local moveDir = humanoid.MoveDirection
	if moveDir.Magnitude == 0 then moveDir = rootPart.CFrame.LookVector end
	rootPart.AssemblyLinearVelocity = moveDir * sprintSpeed + Vector3.new(0, 15, 0)
	
	task.delay(0.75, function()
		isRolling = false
		targetFOV = isSprinting and 85 or 70
		if rollTrack.IsPlaying then rollTrack:Stop() end
	end)
end

humanoid.StateChanged:Connect(function(oldState, newState)
	if newState == Enum.HumanoidStateType.Freefall then
		isFalling = true
		fallStartHeight = rootPart.Position.Y
	elseif newState == Enum.HumanoidStateType.Landed then
		if isBackflipping then
			isBackflipping = false
			if backflipTrack.IsPlaying then backflipTrack:Stop() end
		end
		
		if isFalling then
			isFalling = false
			local fallDistance = fallStartHeight - rootPart.Position.Y
			
			if fallDistance > safeFallDistance then
				if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
					startRoll()
				else
					humanoid:TakeDamage((fallDistance - safeFallDistance) * fallDamageMultiplier)
				end
			end
		end
	end
end)

local function startDash()
	if isDashing or isClimbing or isWallRunning or isRolling or isBackflipping or isGrappling then return end
	
	isDashing = true
	lastDashTime = tick()
	targetFOV = 100 
	
	dashParticles:Emit(40)
	
	local attachment = Instance.new("Attachment", rootPart)
	attachment.Name = "DashAttachment"
	local lv = Instance.new("LinearVelocity", rootPart)
	lv.Name = "DashVelocity"
	lv.Attachment0 = attachment
	lv.MaxForce = math.huge
	
	local moveDir = humanoid.MoveDirection
	if moveDir.Magnitude == 0 then moveDir = rootPart.CFrame.LookVector end
	lv.VectorVelocity = moveDir * dashSpeed
	
	task.delay(dashTime, function()
		isDashing = false
		targetFOV = isSprinting and 85 or 70 
		if lv then lv:Destroy() end
		if attachment then attachment:Destroy() end
	end)
end

local function startSprint()
	if isSprinting or isSliding or isRolling or isBackflipping or isGrappling then return end
	isSprinting = true
	targetWalkSpeed = sprintSpeed
	targetFOV = 85 
	sprintParticles.Enabled = true
	if not sprintTrack.IsPlaying then sprintTrack:Play() end
end

local function stopSprint()
	if not isSprinting then return end
	isSprinting = false
	targetWalkSpeed = normalSpeed
	targetFOV = 70
	sprintParticles.Enabled = false
	if sprintTrack.IsPlaying then sprintTrack:Stop() end
end

local function stopSlide()
	if not isSliding then return end
	
	local hit = workspace:Raycast(rootPart.Position, Vector3.new(0, 4, 0), raycastParams)
	if hit then
		task.delay(0.1, stopSlide)
		return
	end
	
	isSliding = false
	targetFOV = isSprinting and 85 or 70
	slideParticles.Enabled = false
	if slideTrack.IsPlaying then slideTrack:Stop() end
	clearActionForces()
	
	for _, part in pairs(character:GetChildren()) do
		if part:IsA("BasePart") and (part.Name == "Head" or part.Name == "UpperTorso" or part.Name == "LowerTorso" or part.Name == "Torso") then
			part.CanCollide = true
		end
	end
end

local function startSlide()
	if isSliding or isClimbing or isWallRunning or isRolling or isBackflipping or isGrappling then return end
	local state = humanoid:GetState()
	if state ~= Enum.HumanoidStateType.Running and state ~= Enum.HumanoidStateType.RunningNoPhysics then return end
	
	isSliding = true
	targetFOV = 95 
	slideParticles.Enabled = true
	if not slideTrack.IsPlaying then slideTrack:Play() end
	
	for _, part in pairs(character:GetChildren()) do
		if part:IsA("BasePart") and (part.Name == "Head" or part.Name == "UpperTorso" or part.Name == "LowerTorso" or part.Name == "Torso") then
			part.CanCollide = false
		end
	end
	
	local attachment = Instance.new("Attachment", rootPart)
	attachment.Name = "ActionAttachment"
	local lv = Instance.new("LinearVelocity", rootPart)
	lv.Name = "ActionVelocity"
	lv.Attachment0 = attachment
	lv.ForceLimitMode = Enum.ForceLimitMode.PerAxis
	lv.MaxAxesForce = Vector3.new(math.huge, 0, math.huge)
	
	local startTime = tick()
	local connection
	connection = RunService.Heartbeat:Connect(function()
		if not isSliding then
			connection:Disconnect()
			return
		end
		
		local elapsed = tick() - startTime
		if elapsed >= slideTime then
			clearActionForces()
			stopSlide()
		else
			local currentSpeed = slideSpeed + (normalSpeed - slideSpeed) * (elapsed / slideTime)
			if rootPart:FindFirstChild("ActionVelocity") then
				rootPart.ActionVelocity.VectorVelocity = rootPart.CFrame.LookVector * currentSpeed
			end
		end
	end)
end

local function stopWallActions()
	isClimbing = false
	isWallRunning = false
	targetFOV = isSprinting and 85 or 70
	wallParticles.Enabled = false
	clearActionForces()
end

local function attemptWallClimb()
	local hit = workspace:Raycast(rootPart.Position, rootPart.CFrame.LookVector * 3, raycastParams)
	if hit then
		isClimbing = true
		targetFOV = 85
		actionEndTime = tick() + maxClimbTime
		wallParticles.Enabled = true
		
		local attachment = Instance.new("Attachment", rootPart)
		attachment.Name = "ActionAttachment"
		local lv = Instance.new("LinearVelocity", rootPart)
		lv.Name = "ActionVelocity"
		lv.Attachment0 = attachment
		lv.MaxForce = math.huge
		lv.VectorVelocity = Vector3.new(0, climbSpeed, 0)
		return true
	end
	return false
end

local function attemptWallRun()
	local rightRay = workspace:Raycast(rootPart.Position, rootPart.CFrame.RightVector * 4, raycastParams)
	local leftRay = workspace:Raycast(rootPart.Position, -rootPart.CFrame.RightVector * 4, raycastParams)
	
	local hit = rightRay or leftRay
	if hit then
		isWallRunning = true
		targetFOV = 95
		actionEndTime = tick() + maxWallRunTime
		currentWallNormal = hit.Normal
		wallRunSide = rightRay and "Right" or "Left"
		wallParticles.Enabled = true
		
		local attachment = Instance.new("Attachment", rootPart)
		attachment.Name = "ActionAttachment"
		local lv = Instance.new("LinearVelocity", rootPart)
		lv.Name = "ActionVelocity"
		lv.Attachment0 = attachment
		lv.MaxForce = math.huge
		
		local forward = rootPart.CFrame.LookVector
		local flatForward = Vector3.new(forward.X, 0, forward.Z).Unit
		local runDir = flatForward - (flatForward:Dot(currentWallNormal) * currentWallNormal)
		lv.VectorVelocity = runDir.Unit * wallRunSpeed
		return true
	end
	return false
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.R then
		startGrapple()
	end
	
	if input.KeyCode == Enum.KeyCode.Q then
		if tick() - lastDashTime >= dashCooldown then startDash() end
	end
	
	if input.KeyCode == Enum.KeyCode.LeftShift and UserInputService:IsKeyDown(Enum.KeyCode.W) then
		startSprint()
	elseif input.KeyCode == Enum.KeyCode.W and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
		startSprint()
	end
	
	if input.KeyCode == Enum.KeyCode.C then
		if isSprinting then
			local state = humanoid:GetState()
			if state == Enum.HumanoidStateType.Freefall or state == Enum.HumanoidStateType.Jumping then
				startBackflip()
			else
				startSlide()
			end
		end
	end
	
	if input.KeyCode == Enum.KeyCode.Space then
		if isGrappling then
			stopGrapple()
			rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity + Vector3.new(0, 40, 0) + (camera.CFrame.LookVector * 40)
			return
		end
		
		if isSliding then
			local hit = workspace:Raycast(rootPart.Position, Vector3.new(0, 4, 0), raycastParams)
			if not hit then stopSlide() end
			return
		end
		
		if isWallRunning then
			stopWallActions()
			rootPart.AssemblyLinearVelocity = currentWallNormal * 30 + Vector3.new(0, 35, 0)
			return
		end
		
		local state = humanoid:GetState()
		if isSprinting and (state == Enum.HumanoidStateType.Freefall or state == Enum.HumanoidStateType.Jumping) then
			if not isClimbing and not isWallRunning and not isBackflipping then
				local climbed = attemptWallClimb()
				if not climbed then attemptWallRun() end
			end
		end
	end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
	if input.KeyCode == Enum.KeyCode.W then
		stopSprint()
	end
end)

RunService:BindToRenderStep("SmoothMovement", Enum.RenderPriority.Camera.Value + 1, function(deltaTime)
	player.CameraMode = Enum.CameraMode.LockFirstPerson
	
	humanoid.WalkSpeed = humanoid.WalkSpeed + (targetWalkSpeed - humanoid.WalkSpeed) * 10 * deltaTime
	camera.FieldOfView = camera.FieldOfView + (targetFOV - camera.FieldOfView) * 10 * deltaTime
	
	if isWallRunning then
		targetTilt = (wallRunSide == "Right") and 15 or -15
	elseif isRolling or isBackflipping or isGrappling then
		targetTilt = 0
	else
		local moveDir = rootPart.CFrame:VectorToObjectSpace(humanoid.MoveDirection)
		targetTilt = -moveDir.X * 4 
	end
	
	currentTilt = currentTilt + (targetTilt - currentTilt) * 10 * deltaTime
	
	if isBackflipping then
		flipAngle = flipAngle + (360 / backflipTime) * deltaTime
	else
		flipAngle = 0
	end
	
	camera.CFrame = camera.CFrame * CFrame.Angles(0, 0, math.rad(currentTilt)) * CFrame.Angles(math.rad(flipAngle), 0, 0)
	
	local targetOffset = (isSliding or isRolling) and Vector3.new(0, -1.5, -1) or Vector3.new(0, 0.8, -1)
	humanoid.CameraOffset = humanoid.CameraOffset:Lerp(targetOffset, 10 * deltaTime)
	
	for _, part in pairs(character:GetChildren()) do
		if part:IsA("BasePart") and part.Name ~= "Head" then
			part.LocalTransparencyModifier = 0
		end
	end
end)

RunService.Heartbeat:Connect(function(deltaTime)
	if isFalling then
		if rootPart.Position.Y > fallStartHeight then
			fallStartHeight = rootPart.Position.Y
		end
	end
	
	if isGrappling then
		local dist = (grappleTarget - rootPart.Position).Magnitude
		if dist < 5 then
			stopGrapple()
		else
			if grappleVelocity then
				grappleVelocity.VectorVelocity = (grappleTarget - rootPart.Position).Unit * grappleSpeed
			end
		end
	end

	if isClimbing then
		if tick() >= actionEndTime then
			stopWallActions()
		else
			local hit = workspace:Raycast(rootPart.Position, rootPart.CFrame.LookVector * 3, raycastParams)
			if not hit then
				local ledgeOrigin = rootPart.Position + rootPart.CFrame.LookVector * 3 + Vector3.new(0, 2, 0)
				local ledgeHit = workspace:Raycast(ledgeOrigin, Vector3.new(0, -10, 0), raycastParams)
				stopWallActions()
				if ledgeHit then
					rootPart.AssemblyLinearVelocity = rootPart.CFrame.LookVector * 25 + Vector3.new(0, 20, 0)
				end
			end
		end
		
	elseif isWallRunning then
		if tick() >= actionEndTime then
			stopWallActions()
		else
			local dir = (wallRunSide == "Right") and rootPart.CFrame.RightVector or -rootPart.CFrame.RightVector
			local hit = workspace:Raycast(rootPart.Position, dir * 4, raycastParams)
			
			if not hit then
				stopWallActions()
			else
				currentWallNormal = hit.Normal
				local forward = workspace.CurrentCamera.CFrame.LookVector
				local flatForward = Vector3.new(forward.X, 0, forward.Z).Unit
				local runDir = flatForward - (flatForward:Dot(currentWallNormal) * currentWallNormal)
				
				if rootPart:FindFirstChild("ActionVelocity") and runDir.Magnitude > 0 then
					rootPart.ActionVelocity.VectorVelocity = runDir.Unit * wallRunSpeed
				end
			end
		end
	end
end)
